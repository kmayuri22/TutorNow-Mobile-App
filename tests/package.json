{
  "name": "tutornow-appium-tests",
  "version": "1.0.0",
  "description": "Appium E2E tests for TutorNow Android App",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:auth": "wdio run wdio.conf.js --spec tests/specs/auth.spec.js",
    "test:student": "wdio run wdio.conf.js --spec tests/specs/student.spec.js",
    "test:tutor": "wdio run wdio.conf.js --spec tests/specs/tutor.spec.js",
    "test:admin": "wdio run wdio.conf.js --spec tests/specs/admin.spec.js",
    "test:booking": "wdio run wdio.conf.js --spec tests/specs/booking.spec.js",
    "test:profile": "wdio run wdio.conf.js --spec tests/specs/profile.spec.js",
    "test:uiux": "wdio run wdio.conf.js --spec tests/specs/uiux.spec.js",
    "generate:report": "python generate_report.py"
  },
  "dependencies": {},
  "devDependencies": {
    "@wdio/appium-service": "^8.38.0",
    "@wdio/cli": "^8.38.0",
    "@wdio/local-runner": "^8.38.0",
    "@wdio/mocha-framework": "^8.38.0",
    "@wdio/spec-reporter": "^8.38.0",
    "appium": "^2.11.1",
    "appium-uiautomator2-driver": "^3.7.9",
    "wdio-allure-reporter": "^8.0.0"
  }
}
